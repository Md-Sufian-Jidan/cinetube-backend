model Watchlist {
  id        String   @id @default(uuid())
  
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  
  mediaId   String
  media     Media    @relation(fields: [mediaId], references: [id])
  
  createdAt DateTime @default(now())

  @@unique([userId, mediaId])
  @@map("watchlist")
}
